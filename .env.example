# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# DynamoDB Tables
DYNAMODB_RISK_TABLE=churn-risk-scores
DYNAMODB_INTERVENTION_TABLE=churn-interventions

# Bedrock AgentCore
BEDROCK_AGENT_ID=your_bedrock_agent_id_here
BEDROCK_AGENT_ALIAS_ID=your_bedrock_agent_alias_id_here

# CloudFront
CLOUDFRONT_DISTRIBUTION_DOMAIN=d1234567890.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Model Configuration
MODEL_ARTIFACT_PATH=models/xgboost_churn_model.pkl
FEATURE_VERSION=v2.1

# Application Settings
HIGH_RISK_THRESHOLD=0.7
MEDIUM_RISK_THRESHOLD=0.4

# Data Paths
TRAINING_DATA_PATH=data/hr_employee_attrition.csv
PROCESSED_DATA_PATH=data/processed_features.csv
